<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    xmlns:pandroid="http://schemas.android.com/tools"
    android:id="@+id/ReminderListLayout_LinearLayout_Root"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    pandroid:padding="5dp">


    <androidx.cardview.widget.CardView
        android:id="@+id/ReminderListLayout_CardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="13sp">

        <LinearLayout
            android:id="@+id/ReminderListLayout_LinearLayout_Reminder"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ReminderListLayout_ImageView_Notification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                app:srcCompat="@drawable/ic_notifications_active_black_24dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/ReminderListLayout_TextView_Notification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/at_the_time_of_event"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/ReminderListLayout_ImageButton_Cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="15dp"
                    android:layout_alignParentEnd="true"
                    android:background="@android:color/transparent"
                    app:srcCompat="@drawable/ic_close" />

            </RelativeLayout>


        </LinearLayout>


    </androidx.cardview.widget.CardView>


</LinearLayout>