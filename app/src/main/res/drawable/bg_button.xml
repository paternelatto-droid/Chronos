<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Couleur de fond -->
    <solid android:color="@color/colorPrimary" />

    <!-- Arrondi des coins -->
    <corners android:radius="0dp" />

    <!-- Bordure (optionnelle) -->
    <stroke
        android:width="1dp"
        android:color="@color/colorPrimary" />

    <!-- Padding interne (si tu veux que le bouton ait du padding via le drawable) -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />
</shape>
